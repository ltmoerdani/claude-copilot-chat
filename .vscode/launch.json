{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: compile",
      "env": {
        "VSCODE_NODE_OPTIONS": "--max-old-space-size=4096"
      },
      "extensionDependencies": [
        "GitHub.copilot-chat"
      ]
    }
  ]
}
